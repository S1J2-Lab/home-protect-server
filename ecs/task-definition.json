{
  "family": "home-protect-server-task",
  "taskRoleArn": "arn:aws:iam::641628981583:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::641628981583:role/ecsTaskExecutionRole",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "containerDefinitions": [
    {
      "name": "home-protect-server",
      "image": "641628981583.dkr.ecr.ap-northeast-2.amazonaws.com/home-protect-server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "memory": 768,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "EXTERNAL_MOIS_ADDRESS_KEY", "value": "REPLACE_MOIS" },
        { "name": "EXTERNAL_SEOUL_REAL_TRADE_KEY", "value": "REPLACE_SEOUL_TRADE" },
        { "name": "EXTERNAL_MOLIT_BUILDING_KEY", "value": "REPLACE_MOLIT" },
        { "name": "EXTERNAL_SEOUL_RENT_KEY", "value": "REPLACE_SEOUL_RENT" },
        { "name": "CLOVA_OCR_API_URL", "value": "REPLACE_CLOVA_URL" },
        { "name": "CLOVA_OCR_SECRET_KEY", "value": "REPLACE_CLOVA_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/home-protect-server-task",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
